{
  "name": "notion-job-application-pipeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "auth:wobo": "node --import tsx scripts/auth/login-wobo.ts",
    "auth:handshake": "node --import tsx scripts/auth/login-handshake.ts",
    "auth:jackjill": "node --import tsx scripts/auth/login-jackjill.ts",
    "test:access": "node --import tsx scripts/test/source/access.ts",
    "source:wobo": "node --import tsx scripts/source/wobo.ts",
    "source:handshake": "node --import tsx scripts/source/handshake.ts",
    "source:jackjill": "node --import tsx scripts/source/jackjill.ts",
    "source:jack-empty": "node --import tsx scripts/source/jack-empty.ts",
    "source:all": "node --import tsx scripts/source/source-all.ts",
    "source:all:parallel": "PARALLEL=1 node --import tsx scripts/source/source-all.ts",
    "log:notion:deduped": "node --import tsx scripts/source/log-to-notion-deduped.ts",
    "run-log:basename": "RUN_LOG_SKILL=source node --import tsx scripts/shared/run-log-basename.ts",
    "cleanup:data": "node --import tsx scripts/shared/cleanup-data.ts",
    "scrape:descriptions": "node --import tsx scripts/scrape/scrape-descriptions.ts",
    "write:jobs-needing-descriptions": "node --import tsx scripts/scrape/write-jobs-needing-descriptions.ts",
    "write:scrape-queue": "node --import tsx scripts/scrape/write-scrape-queue.ts",
    "run-log:basename:scraper": "RUN_LOG_SKILL=scrape node --import tsx scripts/shared/run-log-basename.ts",
    "write:jobs-ready-to-apply": "node --import tsx scripts/fill/write-jobs-ready-to-apply.ts",
    "write:fill-queue": "node --import tsx scripts/fill/write-fill-queue.ts",
    "check:url-health": "node --import tsx scripts/fill/check-url-health.ts",
    "fill:application": "node --import tsx scripts/fill/fill-application.ts",
    "run-log:basename:fill": "RUN_LOG_SKILL=fill node --import tsx scripts/shared/run-log-basename.ts"
  },
  "dependencies": {
    "playwright": "^1.52.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
